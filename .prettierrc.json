{
    "bracketSpacing": true,
    "editor.formatOnSave": false,
    "printWidth": 120,
    "proseWrap": "always",
    "requireConfig": false,
    "semi": true,
    "singleQuote": false,
    "spaceWidth": 4,
    "tabWidth": 4,
    "trailingComma": "none",
    "useTabs": false,
    "plugins": ["prettier-plugin-tailwindcss"]
}
